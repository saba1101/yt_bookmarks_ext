{
  "manifest_version": 3,
  "name": "Youtube Bookmarks",
  "version": "1.0.0",
  "description": "Organize and bookmark YouTube videos with folders, play/open saved videos/music",
  "permissions": ["storage", "sidePanel", "activeTab", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Youtube Bookmarks"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
